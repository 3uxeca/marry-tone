generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DiagnosisType {
  PERSONAL_COLOR
  BODY_MEASUREMENTS
  SKELETON_TYPE
}

enum DiagnosisStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ComparisonSetStatus {
  DRAFT
  FINALIZED
  ARCHIVED
}

enum DecisionEventType {
  SAVED
  COMPARED
  FINAL_SELECTED
  DISMISSED
}

enum ProfileSubjectRole {
  BRIDE
  GROOM
}

enum ProfileDiagnosisGateChoice {
  EXPERIENCED
  NOT_EXPERIENCED
}

enum ProfileDiagnosisSourceType {
  SELF_REPORTED
  STUDIO_REPORTED
  AUTO_ANALYZED
  MANUAL_SURVEY
}

enum ProfileLowConfidencePolicy {
  POLICY_C_REUPLOAD_THEN_MANUAL
}

enum ProfileIntakeStatus {
  SUBMITTED
  DIAGNOSIS_IN_PROGRESS
  COMPLETED
}

enum ProfileIntakeNextStep {
  READY_FOR_RECOMMENDATION
  REUPLOAD_REQUIRED
  MANUAL_SURVEY_REQUIRED
}

enum RecommendationRequestType {
  INITIAL
  REGENERATE
}

enum RecommendationGenerationStatus {
  QUEUED
  GENERATING
  COMPLETED
  FAILED
}

enum RecommendationExecutionMode {
  AI_PRIMARY
  RULE_BASED_FALLBACK
}

enum RecommendationFallbackPolicy {
  RULE_BASED_TOP3
}

enum RecommendationRetryState {
  NONE
  RETRYING_ONCE
  RETRY_EXHAUSTED
  MANUAL_SELECTION_REQUIRED
}

enum CoupleConflictResolutionPolicy {
  POLICY_A
}

enum CoupleDecisionStatus {
  PENDING
  AGREED
  POLICY_A_APPLIED
  FINALIZED
}

model User {
  id                String             @id @default(cuid()) @db.VarChar(191)
  email             String             @unique @db.VarChar(191)
  displayName       String?            @db.VarChar(191)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  diagnosisSessions DiagnosisSession[]
  styleCards        StyleCard[]
  comparisonSets    ComparisonSet[]
  decisionEvents    DecisionEvent[]
}

model DiagnosisSession {
  id              String          @id @default(cuid()) @db.VarChar(191)
  userId          String          @db.VarChar(191)
  type            DiagnosisType
  status          DiagnosisStatus @default(PENDING)
  inputObjectKey  String?         @db.VarChar(512)
  result          Json?
  confidence      Float?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  decisionEvents  DecisionEvent[]

  @@index([userId, createdAt])
}

model StyleCard {
  id              String              @id @default(cuid()) @db.VarChar(191)
  userId          String              @db.VarChar(191)
  title           String              @db.VarChar(191)
  category        String              @db.VarChar(64)
  payload         Json
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  comparisonItems ComparisonSetItem[]

  @@index([userId, category])
}

model ComparisonSet {
  id             String              @id @default(cuid()) @db.VarChar(191)
  userId         String              @db.VarChar(191)
  name           String              @db.VarChar(191)
  status         ComparisonSetStatus @default(DRAFT)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          ComparisonSetItem[]
  decisionEvents DecisionEvent[]

  @@index([userId, status])
}

model ComparisonSetItem {
  id              String        @id @default(cuid()) @db.VarChar(191)
  comparisonSetId String        @db.VarChar(191)
  styleCardId     String        @db.VarChar(191)
  rank            Int?
  note            String?       @db.VarChar(512)
  createdAt       DateTime      @default(now())
  comparisonSet   ComparisonSet @relation(fields: [comparisonSetId], references: [id], onDelete: Cascade)
  styleCard       StyleCard     @relation(fields: [styleCardId], references: [id], onDelete: Cascade)

  @@unique([comparisonSetId, styleCardId])
  @@index([styleCardId])
}

model DecisionEvent {
  id                 String            @id @default(cuid()) @db.VarChar(191)
  userId             String            @db.VarChar(191)
  comparisonSetId    String?           @db.VarChar(191)
  diagnosisSessionId String?           @db.VarChar(191)
  eventType          DecisionEventType
  payload            Json?
  createdAt          DateTime          @default(now())
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  comparisonSet      ComparisonSet?    @relation(fields: [comparisonSetId], references: [id], onDelete: SetNull)
  diagnosisSession   DiagnosisSession? @relation(fields: [diagnosisSessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([comparisonSetId])
  @@index([diagnosisSessionId])
}

model ProfileDiagnosisSnapshot {
  id                     String                     @id @default(cuid()) @db.VarChar(191)
  profileId              String                     @db.VarChar(191)
  subjectRole            ProfileSubjectRole
  gateChoice             ProfileDiagnosisGateChoice
  sourceType             ProfileDiagnosisSourceType
  intakeStatus           ProfileIntakeStatus
  nextStep               ProfileIntakeNextStep
  lowConfidencePolicy    ProfileLowConfidencePolicy?
  diagnosisSummary       Json?
  checklistSummary       Json?
  checklistTotalItems    Int                        @default(0)
  checklistCompletedItems Int                       @default(0)
  checklistCompletionRate Decimal                   @default(0.00) @db.Decimal(5, 2)
  isChecklistCompleted   Boolean                    @default(false)
  selectedAt             DateTime?                  @db.DateTime(3)
  processedAt            DateTime?                  @db.DateTime(3)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  @@index([profileId, createdAt])
  @@index([profileId, updatedAt])
  @@index([intakeStatus, updatedAt])
}

model RecommendationSnapshot {
  id              String                         @id @default(cuid()) @db.VarChar(191)
  recommendationId String                        @unique @db.VarChar(191)
  profileId       String                         @db.VarChar(191)
  coupleId        String                         @db.VarChar(191)
  requestType     RecommendationRequestType
  status          RecommendationGenerationStatus
  executionMode   RecommendationExecutionMode
  fallbackPolicy  RecommendationFallbackPolicy?
  retryState      RecommendationRetryState
  retriedCount    Int                            @default(0)
  maxOptions      Int                            @default(3)
  mainOptionId    String?                        @db.VarChar(191)
  contextSnapshot Json?
  optionsSnapshot Json?
  failureReason   String?                        @db.VarChar(512)
  requestedAt     DateTime                       @default(now())
  completedAt     DateTime?                      @db.DateTime(3)
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@index([profileId, requestedAt])
  @@index([coupleId, requestedAt])
  @@index([status, requestedAt])
}

model CoupleConsensusDecision {
  id               String                         @id @default(cuid()) @db.VarChar(191)
  decisionId       String                         @unique @db.VarChar(191)
  coupleId         String                         @db.VarChar(191)
  profileId        String                         @db.VarChar(191)
  recommendationId String                         @db.VarChar(191)
  selectedOptionId String                         @db.VarChar(191)
  policy           CoupleConflictResolutionPolicy @default(POLICY_A)
  status           CoupleDecisionStatus
  votes            Json
  latestEvent      Json
  decidedAt        DateTime                       @default(now())
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  @@index([profileId, decidedAt])
  @@index([coupleId, decidedAt])
  @@index([recommendationId, decidedAt])
}
